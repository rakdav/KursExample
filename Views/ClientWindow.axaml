<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
		Width="400" Height="500"
        x:Class="KursMVVM.ClientWindow"
        xmlns:view="using:KursMVVM"
		Title="ClientWindow"
		x:DataType="view:ClientWindow">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<TextBox Grid.Row="0" Text="{Binding Client.FirstName}"/>
		<TextBox Grid.Row="1" Text="{Binding Client.LastName}"/>
		<TextBox Grid.Row="0" Text="{Binding Client.FirstName}"/>
	</Grid>
</Window>
