<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="550"
        x:Class="KursMVVM.ClientWindow"
        Title="ClientWindow">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<TextBox Grid.Row="0" Text="{Binding FirstName}"/>
		<TextBox Grid.Row="1" Text="{Binding LastName}"/>
		<TextBox Grid.Row="2" Text="{Binding SurName}"/>
		<TextBox Grid.Row="3" Text="{Binding Address}"/>
		<TextBox Grid.Row="4" Text="{Binding Phone}"/>
		<TextBox Grid.Row="5" Text="{Binding NumberDogovor}"/>
		<DatePicker Grid.Row="6" SelectedDate="{Binding DataDogovor}"/>
		<Grid Grid.Row="7">
			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Button Grid.Column="0"/>
			<Button Grid.Column="1"/>
		</Grid>
	</Grid>
</Window>
